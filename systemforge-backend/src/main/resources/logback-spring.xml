<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback configuration for SystemForge.

  Profile-aware:
  - "dev" profile  → Console-only, human-readable pattern layout
  - "prod" profile → JSON structured logging (ELK/Datadog-ready)
  - Both profiles  → File appender with rolling policy

  MDC fields automatically included: correlationId, userId
-->
<configuration scan="true" scanPeriod="30 seconds">

    <!-- ─── Properties ──────────────────────────────────────────────────── -->
    <property name="LOG_DIR" value="logs" />
    <property name="APP_NAME" value="systemforge-backend" />
    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{correlationId:-}] %-5level %logger{36} - %msg%n" />

    <!-- ─── DEV Profile: Human-readable console ─────────────────────────── -->
    <springProfile name="dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${CONSOLE_PATTERN}</pattern>
            </encoder>
        </appender>

        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/systemforge.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/systemforge.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>7</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${CONSOLE_PATTERN}</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
        </root>

        <logger name="com.systemforge" level="DEBUG" />
        <logger name="org.springframework.security" level="DEBUG" />
        <logger name="org.hibernate.SQL" level="DEBUG" />
    </springProfile>

    <!-- ─── PROD Profile: JSON structured logging ──────────────────────── -->
    <springProfile name="prod">
        <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"app":"${APP_NAME}","env":"production"}</customFields>
                <includeMdcKeyName>correlationId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>jobId</includeMdcKeyName>
            </encoder>
        </appender>

        <appender name="FILE_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/systemforge.json.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/systemforge.%d{yyyy-MM-dd}.%i.json.log</fileNamePattern>
                <maxFileSize>100MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>2GB</totalSizeCap>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"app":"${APP_NAME}","env":"production"}</customFields>
                <includeMdcKeyName>correlationId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>jobId</includeMdcKeyName>
            </encoder>
        </appender>

        <root level="WARN">
            <appender-ref ref="CONSOLE_JSON" />
            <appender-ref ref="FILE_JSON" />
        </root>

        <logger name="com.systemforge" level="INFO" />
        <logger name="org.springframework.security" level="WARN" />
        <logger name="org.hibernate.SQL" level="WARN" />
    </springProfile>

</configuration>
